{
  "name": "site-builder-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5177",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:report": "npx playwright test --reporter=json > e2e-results.json 2>&1 || true",
    "test:all": "vitest run && npx playwright test"
  },
  "dependencies": {
    "@tinymce/tinymce-vue": "^6.3.0",
    "pinia": "^2.2.0",
    "tinymce": "^8.3.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.3",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.1.0"
  }
}
